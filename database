-- ─── TABLE: clients ──────────────────────────────────────────────────────────

CREATE TABLE public.clients (
    id            SERIAL PRIMARY KEY,
    first_name    VARCHAR(100)  NOT NULL,
    last_name     VARCHAR(100)  NOT NULL,
    email         VARCHAR(255)  UNIQUE NOT NULL,
    phone         VARCHAR(30)   NOT NULL,
    password_hash VARCHAR(255)  NOT NULL,
    marital_status VARCHAR(20)  DEFAULT NULL,
    number_of_children INTEGER  DEFAULT 0,
    city          VARCHAR(100)  DEFAULT NULL,
    created_at    TIMESTAMP WITH TIME ZONE DEFAULT NOW() NOT NULL,
    updated_at    TIMESTAMP WITH TIME ZONE DEFAULT NOW() NOT NULL,
    CONSTRAINT clients_marital_status_check CHECK (
        marital_status IS NULL OR
        marital_status = ANY(ARRAY['celibataire','marie','divorce','veuf'])
    )
);

CREATE INDEX idx_clients_email ON public.clients USING btree (email);

CREATE TRIGGER trg_clients_updated_at
    BEFORE UPDATE ON public.clients
    FOR EACH ROW EXECUTE FUNCTION public.set_updated_at();

-- ─── TABLE: omra_packages ────────────────────────────────────────────────────

CREATE TABLE public.omra_packages (
    id          SERIAL PRIMARY KEY,
    title       VARCHAR(255)  NOT NULL,
    subtitle    VARCHAR(255)  DEFAULT NULL,
    description TEXT          DEFAULT NULL,
    image_url   VARCHAR(500)  DEFAULT NULL,
    price       NUMERIC(10,2) NOT NULL,
    old_price   NUMERIC(10,2) DEFAULT NULL,
    duration    INTEGER       NOT NULL DEFAULT 14,
    departure   VARCHAR(100)  DEFAULT NULL,
    spots       INTEGER       NOT NULL DEFAULT 50,
    rating      NUMERIC(3,1)  NOT NULL DEFAULT 5.0,
    reviews     INTEGER       NOT NULL DEFAULT 0,
    badge       VARCHAR(50)   DEFAULT NULL,
    includes    JSONB         NOT NULL DEFAULT '[]'::jsonb,
    is_active   BOOLEAN       NOT NULL DEFAULT TRUE,
    created_at  TIMESTAMP WITH TIME ZONE DEFAULT NOW() NOT NULL,
    updated_at  TIMESTAMP WITH TIME ZONE DEFAULT NOW() NOT NULL,
    CONSTRAINT omra_packages_price_check    CHECK (price > 0),
    CONSTRAINT omra_packages_duration_check CHECK (duration > 0),
    CONSTRAINT omra_packages_spots_check    CHECK (spots >= 0)
);

CREATE INDEX idx_omra_packages_active  ON public.omra_packages USING btree (is_active);
CREATE INDEX idx_omra_packages_created ON public.omra_packages USING btree (created_at DESC);

CREATE TRIGGER trg_omra_packages_updated_at
    BEFORE UPDATE ON public.omra_packages
    FOR EACH ROW EXECUTE FUNCTION public.set_updated_at();

-- ─── TABLE: omra_reservations ────────────────────────────────────────────────

CREATE TABLE public.omra_reservations (
    id                SERIAL PRIMARY KEY,
    package_id        INTEGER REFERENCES public.omra_packages(id) ON DELETE SET NULL,
    first_name        VARCHAR(100)  NOT NULL,
    last_name         VARCHAR(100)  NOT NULL,
    email             VARCHAR(255)  NOT NULL,
    phone             VARCHAR(30)   NOT NULL,
    gender            VARCHAR(10)   NOT NULL,
    has_mahram        VARCHAR(5)    DEFAULT NULL,
    passport_number   VARCHAR(50)   NOT NULL,
    chambre_type      VARCHAR(20)   NOT NULL DEFAULT 'double',
    number_of_persons INTEGER       NOT NULL DEFAULT 1,
    total_price       NUMERIC(10,2) NOT NULL,
    payment_method    VARCHAR(20)   NOT NULL DEFAULT 'agency',
    payment_status    VARCHAR(20)   NOT NULL DEFAULT 'pending',
    status            VARCHAR(20)   NOT NULL DEFAULT 'pending',
    notes             TEXT          DEFAULT NULL,
    created_at        TIMESTAMP WITH TIME ZONE DEFAULT NOW() NOT NULL,
    updated_at        TIMESTAMP WITH TIME ZONE DEFAULT NOW() NOT NULL,
    CONSTRAINT omra_res_payment_method_check  CHECK (payment_method  = ANY(ARRAY['online','agency'])),
    CONSTRAINT omra_res_payment_status_check  CHECK (payment_status  = ANY(ARRAY['pending','paid','refunded'])),
    CONSTRAINT omra_res_status_check          CHECK (status          = ANY(ARRAY['pending','confirmed','cancelled','completed'])),
    CONSTRAINT omra_res_gender_check          CHECK (gender          = ANY(ARRAY['homme','femme'])),
    CONSTRAINT omra_res_chambre_check         CHECK (chambre_type    = ANY(ARRAY['single','double','triple'])),
    CONSTRAINT omra_res_persons_check         CHECK (number_of_persons >= 1)
);

CREATE INDEX idx_omra_res_package ON public.omra_reservations USING btree (package_id);
CREATE INDEX idx_omra_res_status  ON public.omra_reservations USING btree (status);
CREATE INDEX idx_omra_res_payment ON public.omra_reservations USING btree (payment_method);
CREATE INDEX idx_omra_res_created ON public.omra_reservations USING btree (created_at DESC);
CREATE INDEX idx_omra_res_email   ON public.omra_reservations USING btree (email);

CREATE TRIGGER trg_omra_res_updated_at
    BEFORE UPDATE ON public.omra_reservations
    FOR EACH ROW EXECUTE FUNCTION public.set_updated_at();

