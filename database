-- ─── FUNCTIONS ───────────────────────────────────────────────────────────────

CREATE FUNCTION public.set_updated_at() RETURNS trigger
    LANGUAGE plpgsql AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$;
ALTER FUNCTION public.set_updated_at() OWNER TO postgres;

CREATE FUNCTION public.update_contact_updated_at() RETURNS trigger
    LANGUAGE plpgsql AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$;
ALTER FUNCTION public.update_contact_updated_at() OWNER TO postgres;

CREATE FUNCTION public.update_custom_trips_updated_at() RETURNS trigger
    LANGUAGE plpgsql AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$;
ALTER FUNCTION public.update_custom_trips_updated_at() OWNER TO postgres;

SET default_tablespace = '';
SET default_table_access_method = heap;

-- ─── TABLE: contact_messages ─────────────────────────────────────────────────

CREATE TABLE public.contact_messages (
    id SERIAL PRIMARY KEY,
    nom character varying(150) NOT NULL,
    email character varying(255) NOT NULL,
    telephone character varying(30),
    sujet character varying(50) NOT NULL,
    message text NOT NULL,
    status character varying(20) DEFAULT 'nouveau' NOT NULL,
    admin_notes text,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL,
    CONSTRAINT contact_messages_status_check CHECK ((status = ANY (ARRAY['nouveau','lu','repondu','archive']))),
    CONSTRAINT contact_messages_sujet_check CHECK ((sujet = ANY (ARRAY['omra','voyage','transport','hotel','sur-mesure','autre'])))
);
ALTER TABLE public.contact_messages OWNER TO postgres;

-- ─── TABLE: custom_trips ─────────────────────────────────────────────────────

CREATE TABLE public.custom_trips (
    id SERIAL PRIMARY KEY,
    destination character varying(255) NOT NULL,
    departure_date date NOT NULL,
    return_date date NOT NULL,
    number_of_persons integer DEFAULT 1 NOT NULL,
    max_budget numeric(10,2),
    include_hotel boolean DEFAULT false NOT NULL,
    hotel_category character varying(10),
    room_type character varying(50),
    pension character varying(50),
    include_transport boolean DEFAULT false NOT NULL,
    transport_type character varying(50),
    departure_city character varying(255),
    luggage character varying(50),
    include_guide boolean DEFAULT false NOT NULL,
    guide_language character varying(50),
    guide_duration character varying(50),
    status character varying(50) DEFAULT 'pending' NOT NULL,
    admin_notes text,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL,
    full_name character varying(255),
    email character varying(255),
    phone character varying(50),
    CONSTRAINT custom_trips_status_check CHECK ((status = ANY (ARRAY['pending','confirmed','cancelled','completed'])))
);
ALTER TABLE public.custom_trips OWNER TO postgres;

-- ─── TABLE: transport_requests ───────────────────────────────────────────────

CREATE TABLE public.transport_requests (
    id SERIAL PRIMARY KEY,
    service_type character varying(30) NOT NULL,
    trip_type character varying(20),
    duration_type character varying(20),
    number_of_days integer DEFAULT 1,
    departure_location character varying(255) NOT NULL,
    arrival_location character varying(255),
    departure_date date NOT NULL,
    departure_time time without time zone NOT NULL,
    return_date date,
    return_time time without time zone,
    flight_train_number character varying(30),
    vehicle_type character varying(20) NOT NULL,
    passengers integer DEFAULT 1 NOT NULL,
    luggage integer DEFAULT 0 NOT NULL,
    child_seat boolean DEFAULT false NOT NULL,
    accessibility boolean DEFAULT false NOT NULL,
    full_name character varying(150) NOT NULL,
    email character varying(150) NOT NULL,
    phone character varying(30) NOT NULL,
    free_text text,
    status character varying(20) DEFAULT 'pending' NOT NULL,
    admin_notes text,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL,
    CONSTRAINT transport_requests_duration_type_check CHECK ((duration_type = ANY (ARRAY['demi-journee','journee-complete','multi-jours']))),
    CONSTRAINT transport_requests_luggage_check CHECK ((luggage >= 0 AND luggage <= 30)),
    CONSTRAINT transport_requests_passengers_check CHECK ((passengers >= 1 AND passengers <= 60)),
    CONSTRAINT transport_requests_service_type_check CHECK ((service_type = ANY (ARRAY['transfert','mise-a-disposition']))),
    CONSTRAINT transport_requests_status_check CHECK ((status = ANY (ARRAY['pending','confirmed','cancelled','completed']))),
    CONSTRAINT transport_requests_trip_type_check CHECK ((trip_type = ANY (ARRAY['aller-simple','aller-retour']))),
    CONSTRAINT transport_requests_vehicle_type_check CHECK ((vehicle_type = ANY (ARRAY['voiture','minibus','bus'])))
);
ALTER TABLE public.transport_requests OWNER TO postgres;

-- ─── TABLE: transports ───────────────────────────────────────────────────────

CREATE TABLE public.transports (
    id SERIAL PRIMARY KEY,
    transport_name character varying(150) NOT NULL,
    transport_type character varying(20) NOT NULL,
